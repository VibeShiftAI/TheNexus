# ==============================================================================
# TheNexus Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# ==============================================================================

# --- Server ---
PORT=4000
PROJECT_ROOT=/path/to/your/projects

# --- AI Provider API Keys ---
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
XAI_API_KEY=your-xai-api-key

# --- Frontend URLs ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CORTEX_URL=http://localhost:8000

# --- Optional: Google Custom Search (for web search tool) ---
# GOOGLE_CSE_ID=your-custom-search-engine-id