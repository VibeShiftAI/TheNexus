[
  {
    "id": "market-research-marco",
    "name": "Market Research Marco",
    "description": "Recursive research loop that gathers market intelligence, evaluates findings, and iteratively improves until quality threshold is met.",
    "domain": "business",
    "graph_pattern": "evaluator-optimizer",
    "config": {
      "icon": "📊",
      "edges": [
        {
          "type": "default",
          "source": "researcher",
          "target": "evaluator"
        },
        {
          "type": "success",
          "source": "evaluator",
          "target": "optimizer",
          "condition": "quality_score >= 0.8"
        },
        {
          "type": "retry",
          "source": "evaluator",
          "target": "researcher",
          "condition": "quality_score < 0.8"
        },
        {
          "type": "success",
          "source": "optimizer",
          "target": "END"
        }
      ],
      "nodes": [
        {
          "id": "researcher",
          "type": "processor",
          "label": "Research Agent",
          "model": "gemini-2.5-flash",
          "tools": [
            "brave_search",
            "fetch_url"
          ]
        },
        {
          "id": "evaluator",
          "type": "processor",
          "label": "Quality Evaluator",
          "model": "gemini-2.5-flash",
          "tools": []
        },
        {
          "id": "optimizer",
          "type": "processor",
          "label": "Insight Optimizer",
          "model": "gemini-2.5-pro",
          "tools": []
        }
      ],
      "mcp_servers": [
        "brave-search",
        "fetch",
        "notion"
      ],
      "checkpointer": "memory",
      "output_schema": {
        "format": "json",
        "schema": {
          "type": "object",
          "properties": {
            "trends": {
              "type": "array"
            },
            "competitors": {
              "type": "array"
            },
            "market_size": {
              "type": "object"
            },
            "recommendations": {
              "type": "array"
            },
            "executive_summary": {
              "type": "string"
            }
          }
        }
      },
      "system_prompt": "You are Market Research Marco, an AI specialist in competitive intelligence and market analysis. Your goal is to gather comprehensive market data, identify trends, and deliver actionable insights.\n\n## Primary Objective\nConduct thorough market research on the given topic, iterating until findings meet quality standards.\n\n## Communication Style\nMaintain a professional, data-driven tone. Present findings with supporting evidence.\n\n## Output Format\nDeliver results as structured JSON with sections for: executive_summary, market_size, competitors, trends, recommendations.",
      "autonomy_level": "autonomous",
      "interrupt_nodes": [],
      "recursion_limit": 10,
      "negative_constraints": [
        "Do not present unverified claims as facts",
        "Do not rely on data older than 12 months without noting it",
        "Do not ignore competitor analysis"
      ]
    },
    "preview_image": null,
    "is_featured": true,
    "usage_count": 0,
