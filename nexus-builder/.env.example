# LangGraph Engine Environment Variables
# Copy to .env and fill in your values

# Supabase/PostgreSQL connection (same as Node.js backend)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# AI Provider API Keys
GOOGLE_API_KEY=your_google_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Node.js backend URL (for proxying requests)
NODEJS_BACKEND_URL=http://localhost:4000

# --- Media adapters (YouTube channel workflow) ---
# Per-call pricing constants live in each adapter module, not here.
# ElevenLabs TTS — copy the same key Praxis uses so the voice stays consistent.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# Nano Banana 2 (Google image generation). See tools/media/nano_banana.py.
NANO_BANANA_API_KEY=
# Override the Gemini image model ID if Google rotates it.
# NANO_BANANA_MODEL_ID=gemini-2.5-flash-image

# Veo 3 (Google video generation — output includes music). See tools/media/veo.py.
VEO_API_KEY=
# Override the Veo model ID / poll cadence if defaults don't match current API.
# VEO_MODEL_ID=veo-3.0-generate-preview
# VEO_POLL_INTERVAL_S=6
# VEO_POLL_TIMEOUT_S=300

# YouTube Data API — upload is always private. See tools/media/youtube.py.
# Refresh token persists to TheNexus/.secrets/youtube_oauth.json (gitignored).
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Praxis data dir — Python reads youtube_episodes from Praxis/data/youtube.db.
# Only override if Praxis lives somewhere other than the default.
PRAXIS_DATA_DIR=/Volumes/Projects/Praxis/data
